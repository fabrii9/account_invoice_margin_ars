<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_margin_ars" model="ir.ui.view">
        <field name="name">account.move.form.invoice.margin.ars</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Buscamos display_type dentro de invoice_line_ids sin importar si es list/tree -->
            <xpath expr="//field[@name='invoice_line_ids']//field[@name='display_type']" position="before">
                <field name="cost_ars" optional="show" readonly="1"/>
                <field name="margin_ars" optional="show" readonly="1"/>
                <field name="margin_percent" optional="show" readonly="1" widget="percentage"/>
            </xpath>
        </field>
    </record>
</odoo>
